{
    "name": "balefireict/balefire-components",
    "description": "Balefire WordPress shortcode component monorepo - a collection of [bma_*] shortcode packages consumed by balefire-base and any derivative balefire theme.",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "authors": [
        { "name": "Balefire Marketing + Advertising", "homepage": "https://balefireagency.com" }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "./packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "require": {
        "php": ">=8.1",
        "balefireict/component-image-helper": "dev-main",
        "balefireict/component-arrow": "dev-main",
        "balefireict/component-href": "dev-main",
        "balefireict/component-buttons": "dev-main",
        "balefireict/component-image-text-list": "dev-main",
        "balefireict/component-logo-grid": "dev-main",
        "balefireict/component-brand-icon-cards": "dev-main",
        "balefireict/component-latest-blog": "dev-main",
        "balefireict/component-accordion-faq": "dev-main",
        "balefireict/component-content-section": "dev-main",
        "balefireict/component-cta-banner": "dev-main",
        "balefireict/component-feature-grid": "dev-main",
        "balefireict/component-footer": "dev-main",
        "balefireict/component-gravity-form-block": "dev-main",
        "balefireict/component-header-split": "dev-main",
        "balefireict/component-hero": "dev-main",
        "balefireict/component-logo-card": "dev-main",
        "balefireict/component-stat-callout": "dev-main",
        "balefireict/component-testimonial": "dev-main"
    },
    "require-dev": {
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "scripts": {
        "phpcs": "phpcs --standard=phpcs.xml.dist packages/",
        "phpcbf": "phpcbf --standard=phpcs.xml.dist packages/"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
