{
    "name": "balefireict/component-simple-text-card",
    "description": "BMA Simple Text Card - text-only info card with eyebrow, title, body, background color picker, and text align. Single-element WPBakery shortcode, vanilla CSS.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Balefire\\Component\\SimpleTextCard\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "extra": {
        "balefire-component": {
            "slug": "simple-text-card",
            "type": "scaffolding",
            "shortcode": "bma_simple_text_card",
            "css_class": "simple-text-card",
            "owns_css": true
        }
    }
}
