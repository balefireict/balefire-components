{
    "name": "balefireict/component-logo-card",
    "description": "Logo card / partner logo strip component for Balefire classic-theme builds.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Balefire\\Component\\LogoCard\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
