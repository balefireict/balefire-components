{
    "name": "balefireict/component-image",
    "description": "BMA Image - single image with fit, crop, aspect ratio, and rounded corner controls. WPBakery element, vanilla CSS.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Balefire\\Component\\Image\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "extra": {
        "balefire-component": {
            "slug": "image",
            "type": "scaffolding",
            "shortcode": "bma_image",
            "css_class": "bma-image",
            "owns_css": true
        }
    }
}
