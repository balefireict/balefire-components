{
    "name": "balefireict/component-template",
    "description": "Template scaffold for Balefire components. Copy this directory and replace TEMPLATE with your component slug.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Balefire\\Component\\Template\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "extra": {
        "balefire-component": {
            "slug": "template",
            "type": "scaffolding",
            "shortcode": "bma_template",
            "css_class": "bma-c-template"
        }
    }
}
