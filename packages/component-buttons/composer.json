{
    "name": "balefireict/component-buttons",
    "description": "BMA Buttons shortcode - pair of buttons (primary/secondary) with style, size, arrow, and alignment. Vanilla CSS, [bma_buttons] shortcode + WPBakery vc_map.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Balefire\\Component\\Buttons\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "extra": {
        "balefire-component": {
            "slug": "buttons",
            "type": "scaffolding",
            "shortcode": "bma_buttons",
            "css_class": "bma-buttons",
            "owns_css": true
        }
    }
}
