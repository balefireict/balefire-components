{
    "name": "balefireict/component-feature-grid",
    "description": "Feature grid section component for Balefire classic-theme builds.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Balefire\\Component\\FeatureGrid\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "extra": {
        "balefire-component": {
            "slug": "feature-grid",
            "type": "field-group",
            "shortcode": "bma_feature_grid",
            "css_class": "bma-c-feature-grid",
            "owns_css": true
        }
    }
}
