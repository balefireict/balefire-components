    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Balefire\\Component\\CardIconTop\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "extra": {
        "balefire-component": {
            "slug": "card-icon-top",
            "type": "scaffolding",
            "shortcode": "bma_card_icon_top",
            "css_class": "card-icon-top",
            "owns_css": true
        }
    }
}
