{
    "name": "balefireict/component-footer",
    "description": "Site footer component for Balefire classic-theme builds. Theme owns styles.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Balefire\\Component\\Footer\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "extra": {
        "balefire-component": {
            "slug": "footer",
            "type": "scaffolding",
            "shortcode": "bma_footer",
            "css_class": "bma-c-footer",
            "owns_css": false,
            "menu_locations": [ "footer-nav" ]
        }
    }
}
