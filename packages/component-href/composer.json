{
    "name": "balefireict/component-href",
    "description": "Link resolver helper: internal page ID or external URL to absolute href. Pure PHP, no CSS, no shortcode.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Balefire\\Component\\Href\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "extra": {
        "balefire-component": {
            "slug": "href",
            "type": "helper",
            "shortcode": null,
            "css_class": null,
            "owns_css": false
        }
    }
}
