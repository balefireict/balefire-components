{
    "name": "balefireict/component-testimonial",
    "description": "Testimonial section component for Balefire classic-theme builds.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "Balefire\\Component\\Testimonial\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "extra": {
        "balefire-component": {
            "slug": "testimonial",
            "type": "scaffolding",
            "shortcode": "bma_testimonial",
            "css_class": "bma-c-testimonial",
            "owns_css": true
        }
    }
}
