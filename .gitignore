# Composer — each package has its own vendor/ when required standalone
**/vendor/
**/composer.lock

# Build outputs
**/dist/
**/build/
**/*.min.css
**/*.min.js

# Exception: vendored third-party libraries shipped inside component asset
# dirs are source, not build output — they must ship with the package.
!packages/*/src/assets/*.min.js
!packages/*/src/assets/*.min.css

# Node
**/node_modules/
**/package-lock.json
**/pnpm-lock.yaml
**/yarn.lock

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Local env
.env
.env.local
